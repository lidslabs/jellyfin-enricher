# Jellyfin connection
JELLYFIN_API_KEY=replace-with-an-admin-api-key

# Login credentials for the enricher web UI
ENRICHER_USER=admin
ENRICHER_PASSWORD=change-me-to-something-real

# Session cookie signing key. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Rotating this value invalidates all existing sessions.
SESSION_SECRET=replace-me-with-a-long-random-string

# Set true when serving behind TLS (e.g., BunkerWeb). Cookies will then
# refuse to transmit over plain HTTP, which breaks 127.0.0.1 access.
SESSION_HTTPS_ONLY=false

# --- Optional: login page splash background ---
# Drop splash.{jpg,png,webp} into ./data to use as the login background.
# Uncomment any of the below to override defaults.
#
# Overlay opacity: 0.0 = no dark overlay, 1.0 = fully dark.
# Default is 0.65 when unset.
# SPLASH_OVERLAY_OPACITY=0.65
#
# CSS backdrop-filter blur. Examples: "4px", "8px", "" for none.
# Default is "" (no blur) when unset.
# SPLASH_BLUR=4px

# --- Optional: logging ---
LOG_LEVEL=INFO

# --- Optional: path translation ---
# Set if your enricher mounts paths differ from Jellyfin's.
# Format: from1:to1,from2:to2,...
# PATH_MAPPINGS=/mnt/jellyfin/movies:/data/media1/movies

# --- Optional: yt-dlp cookies ---
# Set when YouTube starts requiring sign-in. Use a throwaway account.
# YTDLP_COOKIES_FILE=/var/lib/enricher/cookies.txt
